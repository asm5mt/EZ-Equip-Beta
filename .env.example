# Copy this file to .env and fill in real values for your environment.
# See README.md's "Quick start" and "Run with Docker" sections for the
# full setup walkthrough — this file only documents what each variable does.

# Required. PostgreSQL connection string. The app refuses to start without
# it (server/storage.ts throws on boot if unset).
DATABASE_URL=postgres://ez_equip:ez_equip@localhost:5433/ez_equip

# Required. Secret used to sign session cookies. The app refuses to start
# without it (server/index.ts throws on boot if unset). Use a long, random,
# unguessable string — anyone with this value can forge valid sessions.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional. One-time bootstrap password applied to the first system-admin
# account that still has no password set (e.g. a fresh install before
# anyone has logged in). It has no effect once that account already has a
# password — safe to leave set permanently, but rotate/remove it after
# first login for security. Must be at least 8 characters.
ADMIN_BOOTSTRAP_PASSWORD=change-me-please

# Optional. Port the app listens on. Defaults to 5000 if omitted.
PORT=5000

# Optional. Set to "production" for production builds (docker-compose and
# `npm run start` already set this for you). Affects secure-cookie
# behavior, static asset serving, and error verbosity. Leave unset for
# local development with `npm run dev`.
NODE_ENV=development
